# DeepSeek API key (required)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Reddit API credentials (optional, for Reddit feed sources)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=acgfeed/1.0

# Database path
DATABASE_PATH=./data/acgfeed.db

# Admin API key for protected endpoints
ADMIN_API_KEY=

# Frontend URL (used for CORS configuration)
FRONTEND_URL=http://localhost:3000

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Number of days to retain fetched items
RETENTION_DAYS=7

# Interval in minutes between feed fetches
FETCH_INTERVAL_MINUTES=30
